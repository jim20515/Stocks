# Supabase 設定 (在 Supabase Dashboard -> Settings -> API 取得)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Nuxt 公開設定 (給前端 @nuxtjs/supabase 模組使用，同上)
NUXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=your-anon-public-key

# Anthropic API (選填，如有使用 AI 功能)
NUXT_ANTHROPIC_API_KEY=your-anthropic-api-key

# Cron Job 驗證 (選填，用於 /api/cron/daily-snapshot)
CRON_SECRET=your-cron-secret
